generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model MenuItem {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  price       Float
  image       String?
  available   Boolean @default(true)
  featured    Boolean @default(false)
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  image       String?
  date        DateTime
}

model Reservation {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  guests    Int
  date      DateTime
  message   String?
  createdAt DateTime @default(now())
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum GalleryCategory {
  FOOD
  INTERIOR
  BAR
  STAFF
  EVENTS
  KIDS
}

model GalleryImage {
  id        Int             @id @default(autoincrement())
  url       String
  category  GalleryCategory
  featured  Boolean         @default(false)
  title     String?
  createdAt DateTime        @default(now())
}
